#!/bin/bash
# shellcheck shell=bash
# Runs before the borgmatic run starts.
# Mount this directory to /etc/borgmatic.d/ and reference it in your borgmatic config:
#
#   commands:
#     - before: everything
#       run:
#           - /etc/borgmatic.d/before-backup
#
# Requires DOCKERCLI=true and /var/run/docker.sock mounted.
#
# Label containers you want stopped during backup with the "backup" label:
#
#   services:
#     myapp:
#       labels:
#         - backup

timestamp() { date '+%Y-%m-%dT%H:%M:%S'; }

echo "$(timestamp) - Stopping containers labelled 'backup'..."
docker ps -q -f "label=backup" | xargs --no-run-if-empty docker container stop -t 60
echo "$(timestamp) - Done."
