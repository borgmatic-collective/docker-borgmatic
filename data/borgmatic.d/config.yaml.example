---
# see https://torsion.org/borgmatic/reference/configuration/ for full reference
#
# Borgmatic expands ${VAR} references from the container environment,
# so you can keep paths and secrets out of this file:
#
#   environment:
#     - BORG_SOURCE_1=/mnt/data
#     - BORG_REPO=user@borg.example.com:myrepo
#     - BORG_PASSPHRASE=secret          # or use BORG_PASSPHRASE_FILE / FILE__BORG_PASSPHRASE
#     - BORG_HEALTHCHECK_URL=https://hc-ping.com/your-uuid

source_directories:
    - ${BORG_SOURCE_1}
    # - ${BORG_SOURCE_2}

repositories:
    - path: ${BORG_REPO}
      label: remote

exclude_caches: true
one_file_system: true

# Passphrase is read from BORG_PASSPHRASE environment variable.
# Alternatively use encryption_passcommand to read from a file:
# encryption_passcommand: cat /run/secrets/borg-passphrase

compression: auto,lz4
ssh_command: ssh -i /root/.ssh/id_ed25519

# Set an explicit name to avoid archive naming issues when the container is rebuilt
# (the default uses {hostname} which changes between rebuilds and breaks pruning)
archive_name_format: 'myhost-{now:%Y-%m-%dT%H:%M:%S}'

keep_daily: 7
keep_weekly: 4
keep_monthly: 12
keep_yearly: 1

checks:
    - name: repository
      frequency: 2 weeks

# Stop containers before backing up, restart them after (and on error).
# Requires DOCKERCLI=true and /var/run/docker.sock mounted.
# Use before/after everything so containers are not left stopped if the backup fails.
commands:
    - before: everything
      run:
          - echo "Stopping containers."
          - /etc/borgmatic.d/before-backup

    - after: everything
      states:
          - finish
      run:
          - /etc/borgmatic.d/after-backup
          - echo "Backup created."

    - after: everything
      states:
          - fail
      run:
          - echo "Error while creating a backup."
          - /etc/borgmatic.d/failed-backup

# Ping a Healthchecks.io URL on start, success, and failure.
healthchecks:
    ping_url: ${BORG_HEALTHCHECK_URL}
